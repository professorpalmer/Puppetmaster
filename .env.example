# Optional: required only for the Cursor adapter.
CURSOR_API_KEY=

# Provider API keys for the openai, agentic, and (via Hermes) multi-provider adapters.
# Agentic uses whichever key is visible — no external CLI required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Optional: AWS Bedrock for agentic (provider=bedrock) or Claude Code
# (CLAUDE_CODE_USE_BEDROCK=1). Prefer a Bedrock inference-profile model id.
# AWS_BEARER_TOKEN_BEDROCK=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

