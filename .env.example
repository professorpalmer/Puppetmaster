# Optional: bound serialized artifact persistence (Wave 2). Defaults are safe;
# set PUPPETMASTER_ARTIFACT_BOUNDS=0 to disable. Oversized text spills under
# {state_dir}/jobs/<job>/artifact_offload/ with a head/tail preview inline.
# PUPPETMASTER_ARTIFACT_BOUNDS=1
# PUPPETMASTER_ARTIFACT_MAX_BYTES=262144
# PUPPETMASTER_ARTIFACT_TEXT_FIELD_MAX_CHARS=48000
# PUPPETMASTER_ARTIFACT_PATCH_DIFF_MAX_CHARS=20000
# PUPPETMASTER_ARTIFACT_PATCH_FILES_MAX=500

# Optional: bound concurrent threads for safe tool-batch read segments (Wave 5).
# Kill switch PUPPETMASTER_TOOL_BATCH_PARALLEL=0 forces fully sequential batches.
# PUPPETMASTER_TOOL_BATCH_PARALLEL=1
# PUPPETMASTER_TOOL_BATCH_MAX_WORKERS=8

# Optional: process-local provider circuit breaker for agentic calls (Slice 9).
# Opens after consecutive retryable failures; half-open probe after cooldown.
# Kill switch PUPPETMASTER_PROVIDER_CIRCUIT=0 disables admission entirely.
# PUPPETMASTER_PROVIDER_CIRCUIT=1
# PUPPETMASTER_PROVIDER_CIRCUIT_THRESHOLD=3
# PUPPETMASTER_PROVIDER_CIRCUIT_COOLDOWN_SECONDS=30

# Optional: required only for the Cursor adapter.
CURSOR_API_KEY=

# Provider API keys for the openai, agentic, and (via Hermes) multi-provider adapters.
# Agentic uses whichever key is visible — no external CLI required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Optional: AWS Bedrock for agentic (provider=bedrock) or Claude Code
# (CLAUDE_CODE_USE_BEDROCK=1). Prefer a Bedrock inference-profile model id.
# AWS_BEARER_TOKEN_BEDROCK=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

