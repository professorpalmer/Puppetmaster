{
  "name": "puppetmaster-cursor",
  "displayName": "Puppetmaster",
  "description": "Run provider-neutral coding-agent swarms from Cursor.",
  "version": "0.2.0-beta.1",
  "publisher": "professorpalmer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/professorpalmer/Puppetmaster.git",
    "directory": "cursor-extension"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onView:puppetmaster.controlPanel",
    "onCommand:puppetmaster.openPanel",
    "onCommand:puppetmaster.doctor",
    "onCommand:puppetmaster.cursorReview",
    "onCommand:puppetmaster.cursorPlan",
    "onCommand:puppetmaster.claudeImplement",
    "onCommand:puppetmaster.showLast",
    "onCommand:puppetmaster.showLogs",
    "onCommand:puppetmaster.showArtifacts",
    "onCommand:puppetmaster.configureKeys"
  ],
  "main": "./extension.cjs",
  "contributes": {
    "configuration": {
      "title": "Puppetmaster",
      "properties": {
        "puppetmaster.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to run `python -m puppetmaster`."
        },
        "puppetmaster.stateDir": {
          "type": "string",
          "default": ".puppetmaster",
          "description": "Local Puppetmaster state directory, relative to the workspace."
        },
        "puppetmaster.claudeCodeCommand": {
          "type": "string",
          "default": "npx -y @anthropic-ai/claude-code",
          "description": "Claude Code command used by the claude-code adapter."
        },
        "puppetmaster.defaultClaudePermissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": [
            "default",
            "acceptEdits",
            "plan",
            "auto",
            "dontAsk",
            "bypassPermissions"
          ],
          "description": "Default Claude Code permission mode for Puppetmaster runs."
        }
      }
    },
    "commands": [
      {
        "command": "puppetmaster.openPanel",
        "title": "Puppetmaster: Open Control Panel"
      },
      {
        "command": "puppetmaster.configureKeys",
        "title": "Puppetmaster: Configure Provider Keys"
      },
      {
        "command": "puppetmaster.doctor",
        "title": "Puppetmaster: Doctor"
      },
      {
        "command": "puppetmaster.cursorReview",
        "title": "Puppetmaster: Cursor Review"
      },
      {
        "command": "puppetmaster.cursorPlan",
        "title": "Puppetmaster: Cursor Plan"
      },
      {
        "command": "puppetmaster.claudeImplement",
        "title": "Puppetmaster: Claude Code Implement"
      },
      {
        "command": "puppetmaster.showLast",
        "title": "Puppetmaster: Show Last Job"
      },
      {
        "command": "puppetmaster.showLogs",
        "title": "Puppetmaster: Show Logs"
      },
      {
        "command": "puppetmaster.showArtifacts",
        "title": "Puppetmaster: Show Artifacts"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "puppetmaster",
          "title": "Puppetmaster",
          "icon": "media/puppetmaster.svg"
        }
      ]
    },
    "views": {
      "puppetmaster": [
        {
          "id": "puppetmaster.controlPanel",
          "name": "Control Panel",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "puppetmaster.doctor",
          "when": "view == puppetmaster.controlPanel",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "puppetmaster.openPanel"
        },
        {
          "command": "puppetmaster.configureKeys"
        },
        {
          "command": "puppetmaster.doctor"
        },
        {
          "command": "puppetmaster.cursorReview"
        },
        {
          "command": "puppetmaster.cursorPlan"
        },
        {
          "command": "puppetmaster.claudeImplement"
        },
        {
          "command": "puppetmaster.showLast"
        },
        {
          "command": "puppetmaster.showLogs"
        },
        {
          "command": "puppetmaster.showArtifacts"
        }
      ]
    }
  },
  "scripts": {
    "check": "node --check extension.cjs"
  }
}
